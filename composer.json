{
    "name": "shahghasiadil/laravel-bruno-generator",
    "description": "Generate Bruno API collections from Laravel routes with automatic request body inference and environment support",
    "keywords": [
        "laravel",
        "bruno",
        "api",
        "api-client",
        "collection",
        "generator",
        "testing",
        "development-tools"
    ],
    "homepage": "https://github.com/shahghasiadil/laravel-bruno-generator",
    "license": "MIT",
    "authors": [
        {
            "name": "Shahghasi Adil",
            "email": "adil.shahghasi@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1|^8.2|^8.3",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/filesystem": "^10.0|^11.0|^12.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "symfony/yaml": "^6.0|^7.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "larastan/larastan": "^2.9|^3.0",
        "nunomaduro/collision": "^7.10|^8.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "pestphp/pest": "^2.34|^3.0",
        "pestphp/pest-plugin-arch": "^2.7|^3.0",
        "pestphp/pest-plugin-laravel": "^2.4|^3.0",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan-deprecation-rules": "^1.1|^2.0",
        "phpstan/phpstan-phpunit": "^1.3|^2.0",
        "phpstan/phpstan-strict-rules": "^1.5|^2.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "ShahGhasiAdil\\LaravelBrunoGenerator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ShahGhasiAdil\\LaravelBrunoGenerator\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "clear": "@php vendor/bin/testbench package:purge-laravel-bruno-generator --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": [
            "@composer run prepare",
            "@php vendor/bin/testbench workbench:build --ansi"
        ],
        "start": [
            "Composer\\Config::disableProcessTimeout",
            "@composer run build",
            "@php vendor/bin/testbench serve"
        ],
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ShahGhasiAdil\\LaravelBrunoGenerator\\BrunoGeneratorServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
